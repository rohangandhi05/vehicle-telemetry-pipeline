{
  "title": "Vehicle Telemetry Dashboard",
  "uid": "vehicle-telemetry",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Messages Processed / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(telemetry_messages_processed_total[1m]))",
          "legendFormat": "msg/sec"
        }
      ]
    },
    {
      "id": 2,
      "title": "Processing Latency (p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, rate(telemetry_processing_duration_seconds_bucket[1m]))",
          "legendFormat": "p99 latency"
        }
      ]
    },
    {
      "id": 3,
      "title": "Alerts Triggered / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (alert_type) (rate(telemetry_alerts_triggered_total[1m]))",
          "legendFormat": "{{alert_type}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Avg Battery % by Vehicle",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "vehicle_battery_pct",
          "legendFormat": "{{vehicle_id}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 5,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (endpoint) (rate(api_http_requests_total[1m]))",
          "legendFormat": "{{endpoint}}"
        }
      ]
    }
  ]
}
